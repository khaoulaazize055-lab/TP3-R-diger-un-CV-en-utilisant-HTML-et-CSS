 body{
            font-family: Arial, sans-serif;
            margin: 0;
            background: #eee;
        }

        .CV {
            display: flex;
            max-width: 900px;
            margin: 40px auto;
            background: white;
        }

        .left {
            width: 35%;
            background: #26e6ac;
            color: white;
            padding: 20px;
            text-align: center;
        }

        .profile {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            border: 4px solid white;
            margin-bottom: 10px;
        }

        .left h2 {
            margin: 10px 0 5px;
        }

        .section  {
            margin-top: 20px;
            text-align: left;

        }

        .section h3 {
            border-bottom: 1px solid white;
            padding-bottom: 5px;
            margin-bottom: 10px;
        }
        
        .right {
            width: 65%;
            padding: 10px;
        }
        .right h1 {
            color:#26e6ac;
            border-bottom: 2px solid #26e6ac;
            padding-bottom: 5px;
        }

        .right p {
            color: #555;
        }

        ul {
            padding-left: 20px;
        }
